# Application Configuration
NODE_ENV=production
PORT=8001

# Database Configuration
DATABASE_URL="postgresql://notification_user:notification_pass@postgres:5432/notification_db?schema=public"
DB_USER=notification_user
DB_PASSWORD=notification_pass
DB_NAME=notification_db
DB_HOST=postgres
DB_PORT=5432

# Redis Configuration
REDIS_URL="redis://nexmun-redis-prod:6379"
REDIS_HOST=nexmun-redis-prod
REDIS_PORT=6379
REDIS_PASSWORD=


# Default Fallback Domain
FALLBACK_DOMAIN=example.com
FALLBACK_EMAIL=no-reply@example.com
FALLBACK_ORGANIZATION_ID=fallback-default
FALLBACK_ORGANIZATION_NAME=Default Fallback

# Email Sending Infrastructure
SPF_INCLUDE_DOMAIN=amazonses.com
RETURN_PATH_DOMAIN=feedback-smtp.us-east-1.amazonses.com
TRACKING_DOMAIN=track.example.com

# Security Keys (Generate secure keys for production)
ENCRYPTION_KEY=generate-32-character-encryption-key
JWT_SECRET=generate-secure-jwt-secret-key
API_KEY_SALT=generate-secure-api-key-salt

# Rate Limiting
DEFAULT_RATE_LIMIT_HOUR=10000
DEFAULT_RATE_LIMIT_DAY=100000

# Queue Configuration
EMAIL_QUEUE_CONCURRENCY=10
WEBHOOK_QUEUE_CONCURRENCY=20
VERIFICATION_QUEUE_INTERVAL=300000

# Feature Flags
ENABLE_WEBHOOK_DELIVERY=true
ENABLE_EMAIL_TRACKING=true
STRICT_TEMPLATE_VALIDATION=true

# External Services
WEBHOOK_TIMEOUT=30000
DNS_RESOLVER_TIMEOUT=5000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json


EMAIL_PROVIDER=SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SESSION_TOKEN=your-aws-session-token-if-using-temporary-credentials

# Admin Dashboard Auth
ADMIN_AUTH_COOKIE_NAME=admin_session
ADMIN_SESSION_TTL_HOURS=12
FRONTEND_URL=https://admin.example.com
ADMIN_ALLOWED_ORIGINS=https://admin.example.com
ADMIN_SETUP_TOKEN=replace-with-strong-random-token
