# Application Configuration
NODE_ENV=development
PORT=8001

# Database Configuration
DATABASE_URL="postgresql://notification_user:notification_pass@localhost:5433/notification_db?schema=public"
DB_USER=notification_user
DB_PASSWORD=notification_pass
DB_NAME=notification_db
DB_HOST=localhost
DB_PORT=5433

# Redis Configuration
REDIS_URL="redis://:redis_pass@localhost:6380"
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=redis_pass

# Email Provider Configuration
EMAIL_PROVIDER=SES

# AWS SES Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key


DEFAULT_FROM_EMAIL=noreply@example.com

# Default Fallback Domain
FALLBACK_DOMAIN=nexmun.in
FALLBACK_EMAIL=no-reply@nexmun.in

# Email Sending Infrastructure
SPF_INCLUDE_DOMAIN=_spf.nexmun.in
RETURN_PATH_DOMAIN=bounce.nexmun.in
TRACKING_DOMAIN=track.nexmun.in

# Security Keys
ENCRYPTION_KEY=your-32-character-encryption-key-here
JWT_SECRET=your-jwt-secret-key
API_KEY_SALT=your-api-key-salt

# Rate Limiting
DEFAULT_RATE_LIMIT_HOUR=1000
DEFAULT_RATE_LIMIT_DAY=10000

# Queue Configuration
EMAIL_QUEUE_CONCURRENCY=10
WEBHOOK_QUEUE_CONCURRENCY=20
VERIFICATION_QUEUE_INTERVAL=300000 # 5 minutes in ms

# Feature Flags
ENABLE_WEBHOOK_DELIVERY=true
ENABLE_EMAIL_TRACKING=true
STRICT_TEMPLATE_VALIDATION=true

# External Services
WEBHOOK_TIMEOUT=30000 # 30 seconds
DNS_RESOLVER_TIMEOUT=5000 # 5 seconds

# Logging
LOG_LEVEL=info
LOG_FORMAT=json


# Admin Dashboard Auth
ADMIN_AUTH_COOKIE_NAME=admin_session
ADMIN_SESSION_TTL_HOURS=12
FRONTEND_URL=http://localhost:3000
ADMIN_ALLOWED_ORIGINS=http://localhost:3000
ADMIN_SETUP_TOKEN=dev-bootstrap-token
