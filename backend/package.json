{
  "name": "notification-backend",
  "version": "1.0.0",
  "main": "dist/main.js",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "test": "node scripts/verify-ses-production-readiness.js && node scripts/verify-admin-dashboard-readiness.js",
    "cli": "npx --yes ts-node -O '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' --transpile-only scripts/production-cli.ts",
    "start": "node dist/main.js",
    "start:dev": "nodemon",
    "start:debug": "nodemon --config nodemon-debug.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio",
    "prisma:seed": "npx --yes ts-node -O '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' --transpile-only prisma/seed.ts",
    "docker:up": "docker compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "docker:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "docker:up:prod": "docker compose -f docker-compose.prod.yml up -d",
    "docker:down:prod": "docker compose -f docker-compose.prod.yml down",
    "docker:logs:prod": "docker compose -f docker-compose.prod.yml logs -f",
    "service-key:create": "npm run cli -- create-service-key",
    "service-key:create-main": "npx --yes ts-node -O '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' --transpile-only scripts/create-main-backend-key.ts",
    "verify:production": "npm test"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.873.0",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/bull": "^11.0.3",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.14.0",
    "@scalar/nestjs-api-reference": "^0.5.12",
    "@types/nodemailer": "^7.0.1",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "bullmq": "^5.58.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "handlebars": "^4.7.8",
    "nodemailer": "^7.0.5",
    "prisma": "^6.14.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "prisma": {
    "seed": "npx --yes ts-node -O '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' --transpile-only prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
