{
  "name": "notification-system-workspace",
  "private": true,
  "packageManager": "bun@1.2.0",
  "scripts": {
    "frontend:dev": "bun scripts/frontend-runner.mjs dev",
    "frontend:dev:port": "bun scripts/frontend-runner.mjs dev --port=3000",
    "frontend:start": "bun scripts/frontend-runner.mjs start",
    "frontend:build": "bun scripts/frontend-runner.mjs build",
    "backend:dev": "bun apps/backend run dev",
    "backend:start": "bun apps/backend run start",
    "backend:build": "bun apps/backend run build",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
